<view class="tab-bar">
  <view
    class="tab-bar-item {{selected === index ? 'active' : ''}}"
    wx:for="{{list}}"
    wx:key="pagePath"
    data-path="{{item.pagePath}}"
    data-index="{{index}}"
    bindtap="switchTab"
  >
    <view class="tab-bar-icon">
      <image
        class="tab-bar-icon-img"
        src="{{selected === index ? item.iconUrlActive : item.iconUrl}}"
        mode="aspectFit"
      ></image>
      <view class="tab-bar-badge" wx:if="{{item.badge}}">{{item.badge}}</view>
    </view>
    <view class="tab-bar-label" style="color: {{selected === index ? selectedColor : color}}">{{item.text}}</view>
  </view>
</view>
