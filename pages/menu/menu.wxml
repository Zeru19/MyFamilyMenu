<view class="page menu-page">
  <view class="hero">
    <text class="eyebrow">家庭电子菜单</text>
    <view class="title">今晚想吃什么</view>
    <text class="subtitle">点选喜欢的菜，提交后家里就开做啦</text>
  </view>

  <view wx:if="{{loading}}" class="empty">加载中…</view>

  <view wx:elif="{{!dishes.length}}" class="empty">暂无可点菜品</view>

  <view wx:else class="dish-list">
    <view class="dish-card" wx:for="{{dishes}}" wx:key="_id">
      <view class="dish-thumb">
        <image wx:if="{{item.image}}" class="dish-thumb-img" src="{{item.image}}" mode="aspectFill" />
        <view wx:else class="dish-thumb-fallback">
          <text>{{item.firstChar}}</text>
        </view>
      </view>
      <view class="dish-main">
        <view class="dish-head">
          <text class="dish-name">{{item.name}}</text>
          <text class="dish-price">¥{{item.price}}</text>
        </view>
        <view wx:if="{{item.category}}" class="dish-category">{{item.category}}</view>
        <text wx:if="{{item.description}}" class="dish-desc">{{item.description}}</text>
        <view class="dish-bottom">
          <view class="counter">
            <view wx:if="{{item.count}}" class="counter-button minus" data-id="{{item._id}}" bindtap="decrease">-</view>
            <text wx:if="{{item.count}}" class="counter-value">{{item.count}}</text>
            <view class="counter-button add" data-id="{{item._id}}" bindtap="increase">+</view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="note-panel">
    <text class="section-title">备注</text>
    <textarea class="note-textarea" value="{{note}}" bindinput="onNoteInput" placeholder="例如：少油、不要辣、米饭多一点" maxlength="80" />
  </view>

  <view class="checkout-bar">
    <view class="checkout-info">
      <text class="checkout-label">合计 · 共 {{totalCount}} 份</text>
      <view class="checkout-price">¥{{totalPrice}}</view>
    </view>
    <view class="checkout-actions">
      <view class="ghost-btn" bindtap="resetCart">重置</view>
      <view class="primary-btn {{totalCount ? '' : 'disabled'}}" bindtap="submitOrder">提交订单</view>
    </view>
  </view>
</view>
