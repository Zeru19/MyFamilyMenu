.menu-page {
  padding: 0 24rpx 200rpx;
}

.hero {
  margin: 24rpx 0 28rpx;
  padding: 36rpx 32rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #fbe9c7, #f1cf95);
  color: #4a3621;
}

.eyebrow {
  display: block;
  color: #7c5b34;
  font-size: 24rpx;
  letter-spacing: 4rpx;
}

.title {
  margin-top: 10rpx;
  font-size: 48rpx;
  font-weight: 800;
  color: #3a2814;
}

.subtitle {
  display: block;
  margin-top: 12rpx;
  color: #7c5b34;
  font-size: 26rpx;
  line-height: 1.5;
}

.dish-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.dish-card {
  display: flex;
  gap: 24rpx;
  padding: 20rpx;
  border-radius: 18rpx;
  background: #fff;
  box-shadow: 0 4rpx 16rpx rgba(31, 41, 51, 0.05);
}

.dish-thumb {
  flex: 0 0 200rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 14rpx;
  overflow: hidden;
  background: #f5efe3;
}

.dish-thumb-img {
  width: 100%;
  height: 100%;
  display: block;
}

.dish-thumb-fallback {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f4d8a4, #d8a96e);
  color: #fff;
  font-size: 72rpx;
  font-weight: 800;
}

.dish-main {
  flex: 1 1 auto;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.dish-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.dish-name {
  flex: 1 1 auto;
  min-width: 0;
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2933;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.dish-price {
  flex: 0 0 auto;
  color: #b4463a;
  font-size: 30rpx;
  font-weight: 800;
}

.dish-category {
  align-self: flex-start;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: #eef5f1;
  color: #1f7a5b;
  font-size: 22rpx;
  line-height: 1.6;
}

.dish-desc {
  color: #68737d;
  font-size: 26rpx;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}

.dish-bottom {
  margin-top: auto;
  display: flex;
  justify-content: flex-end;
  padding-top: 8rpx;
}

.counter {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.counter-button {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1;
}

.counter-button.add {
  background: #1f7a5b;
  color: #fff;
}

.counter-button.minus {
  background: #fff;
  color: #1f7a5b;
  border: 2rpx solid #1f7a5b;
}

.counter-value {
  min-width: 40rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2933;
}

.empty {
  padding: 80rpx 0;
  color: #68737d;
  text-align: center;
  font-size: 28rpx;
}

.note-panel {
  margin-top: 32rpx;
}

.section-title {
  display: block;
  margin: 0 0 14rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2933;
}

.note-textarea {
  width: 100%;
  min-height: 144rpx;
  padding: 20rpx;
  border-radius: 14rpx;
  background: #fff;
  box-shadow: 0 4rpx 16rpx rgba(31, 41, 51, 0.04);
  font-size: 28rpx;
  line-height: 1.5;
}

.checkout-bar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 20rpx 28rpx calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(31, 41, 51, 0.06);
}

.checkout-info {
  flex: 1 1 auto;
  min-width: 0;
}

.checkout-label {
  display: block;
  color: #68737d;
  font-size: 24rpx;
}

.checkout-price {
  margin-top: 4rpx;
  color: #b4463a;
  font-size: 40rpx;
  font-weight: 800;
}

.checkout-actions {
  flex: 0 0 auto;
  display: flex;
  gap: 14rpx;
}

.ghost-btn,
.primary-btn {
  min-width: 144rpx;
  height: 80rpx;
  padding: 0 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.ghost-btn {
  background: #f1f3f5;
  color: #52606d;
}

.primary-btn {
  background: #1f7a5b;
  color: #fff;
}

.primary-btn.disabled {
  background: #c6dbd1;
}
