<view class="page service-page">
  <view class="topbar">
    <view>
      <text class="eyebrow">服务侧</text>
      <view class="title">订单与菜品</view>
    </view>
    <button class="secondary-button refresh-button" bindtap="loadData">刷新</button>
  </view>

  <view class="section">
    <view class="section-head">
      <text class="section-title">点餐请求</text>
      <button class="danger-button mini-button" bindtap="clearOrders">清空</button>
    </view>

    <view wx:if="{{!orders.length}}" class="empty">
      <text>暂无订单</text>
    </view>

    <view class="order-card" wx:for="{{orders}}" wx:key="id">
      <view class="order-head">
        <view>
          <text class="order-id">{{item.id}}</text>
          <text class="order-time">{{item.createdAt}}</text>
        </view>
        <text class="status status-{{item.status}}">{{item.statusLabel}}</text>
      </view>
      <view class="order-items">
        <view class="order-line" wx:for="{{item.items}}" wx:for-item="dish" wx:key="id">
          <text>{{dish.name}} x {{dish.count}}</text>
          <text>¥{{dish.subtotal}}</text>
        </view>
      </view>
      <view wx:if="{{item.note}}" class="order-note">备注：{{item.note}}</view>
      <view class="order-foot">
        <text>共 {{item.totalCount}} 份，¥{{item.totalPrice}}</text>
        <view class="order-actions">
          <button wx:if="{{item.status === 'pending'}}" class="secondary-button mini-button" data-id="{{item.id}}" bindtap="acceptOrder">接单</button>
          <button wx:if="{{item.status !== 'done'}}" class="primary-button mini-button" data-id="{{item.id}}" bindtap="finishOrder">完成</button>
        </view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <text class="section-title">菜品维护</text>
      <button class="secondary-button mini-button" bindtap="resetDishes">默认</button>
    </view>

    <view class="form-panel">
      <input value="{{dishForm.name}}" data-field="name" bindinput="onDishInput" placeholder="菜名" />
      <input value="{{dishForm.category}}" data-field="category" bindinput="onDishInput" placeholder="分类" />
      <input value="{{dishForm.price}}" data-field="price" bindinput="onDishInput" placeholder="价格" type="digit" />
      <textarea value="{{dishForm.description}}" data-field="description" bindinput="onDishInput" placeholder="描述" maxlength="80" />
      <view class="form-actions">
        <button wx:if="{{editingDishId}}" class="secondary-button" bindtap="cancelEdit">取消</button>
        <button class="primary-button" bindtap="saveDish">{{editingDishId ? '保存修改' : '新增菜品'}}</button>
      </view>
    </view>

    <view class="dish-admin-card" wx:for="{{dishes}}" wx:key="id">
      <view class="dish-admin-main">
        <view class="dish-row">
          <text class="dish-name">{{item.name}}</text>
          <text class="dish-price">¥{{item.price}}</text>
        </view>
        <text class="dish-meta">{{item.category}} · {{item.available ? '已上架' : '已下架'}}</text>
        <text class="dish-desc">{{item.description}}</text>
      </view>
      <view class="dish-actions">
        <button class="secondary-button mini-button" data-id="{{item.id}}" bindtap="editDish">编辑</button>
        <button class="mini-button {{item.available ? 'danger-button' : 'primary-button'}}" data-id="{{item.id}}" bindtap="toggleDish">
          {{item.available ? '下架' : '上架'}}
        </button>
      </view>
    </view>
  </view>
</view>
